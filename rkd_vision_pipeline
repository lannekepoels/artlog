def find_artwork_region(vision_response: dict, img_w: int, img_h: int):
    """
    Find the artwork region using Vision object labels, or infer from text positions.
    Returns a single region dict {x, y, w, h, method} or None.
    """
    artwork_labels = {'painting', 'picture frame', 'illustration', 'art',
                      'picture', 'artwork', 'visual arts', 'drawing'}
    for obj in vision_response.get("localizedObjectAnnotations", []):
        label = obj.get("name", "").lower()
        score = obj.get("score", 0)
        if any(art in label for art in artwork_labels) and score > 0.4:
            verts = obj["boundingPoly"]["normalizedVertices"]
            xs = [v.get("x", 0) * img_w for v in verts]
            ys = [v.get("y", 0) * img_h for v in verts]
            x, y = int(min(xs)), int(min(ys))
            w, h = int(max(xs) - min(xs)), int(max(ys) - min(ys))
            if w > 80 and h > 80:
                return {"x": x, "y": y, "w": w, "h": h, "method": "vision_object"}

    # Fallback: infer from text block positions
    full_text_ann = vision_response.get("fullTextAnnotation", {})
    pages = full_text_ann.get("pages", [])
    if not pages:
        return None

    block_tops = []
    for page in pages:
        for block in page.get("blocks", []):
            verts = block.get("boundingBox", {}).get("vertices", [])
            if verts:
                block_tops.append(min(v.get("y", img_h) for v in verts))

    if not block_tops:
        return None

    lower_blocks = [y for y in block_tops if y > img_h * 0.5]
    label_top    = min(lower_blocks) if lower_blocks else min(block_tops)
    header_bottom  = int(img_h * 0.12)
    artwork_bottom = int(label_top - img_h * 0.03)
    artwork_h      = artwork_bottom - header_bottom

    if artwork_h < 80:
        return None

    pad = int(img_w * 0.03)
    return {"x": pad, "y": header_bottom, "w": img_w - 2 * pad,
            "h": artwork_h, "method": "text_position_inference"}


def find_all_artwork_regions(vision_response: dict, img_w: int, img_h: int) -> list:
    """
    Returns ALL detected artwork regions (handles pages with 2+ artworks).
    Falls back to single-region inference if none detected by object labels.
    """
    artwork_labels = {'painting', 'picture frame', 'illustration', 'art',
                      'picture', 'artwork', 'visual arts', 'drawing'}
    regions = []
    for obj in vision_response.get("localizedObjectAnnotations", []):
        label = obj.get("name", "").lower()
        score = obj.get("score", 0)
        if any(art in label for art in artwork_labels) and score > 0.4:
            verts = obj["boundingPoly"]["normalizedVertices"]
            xs = [v.get("x", 0) * img_w for v in verts]
            ys = [v.get("y", 0) * img_h for v in verts]
            x, y = int(min(xs)), int(min(ys))
            w, h = int(max(xs) - min(xs)), int(max(ys) - min(ys))
            if w > 80 and h > 80:
                regions.append({"x": x, "y": y, "w": w, "h": h, "method": "vision_object"})

    if regions:
        return regions

    single = find_artwork_region(vision_response, img_w, img_h)
    return [single] if single else []


def crop_and_save(image_path: str, region: dict, output_path: str):
    """Crop the detected artwork region and save it."""
    img = Image.open(image_path)
    img_w, img_h = img.size
    x1 = max(0, region["x"])
    y1 = max(0, region["y"])
    x2 = min(img_w, region["x"] + region["w"])
    y2 = min(img_h, region["y"] + region["h"])
    img.crop((x1, y1, x2, y2)).save(output_path)


