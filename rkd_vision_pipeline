def encode_image_to_base64(image_path: str) -> str:
    """Resize image to max 1600px and return base64 string."""
    img = Image.open(image_path)
    max_side = 1600
    w, h = img.size
    if max(w, h) > max_side:
        scale = max_side / max(w, h)
        img = img.resize((int(w * scale), int(h * scale)), Image.LANCZOS)
    if img.mode in ('RGBA', 'P'):
        img = img.convert('RGB')
    buf = io.BytesIO()
    img.save(buf, format='JPEG', quality=85)
    return base64.b64encode(buf.getvalue()).decode("utf-8")


def call_google_vision(image_path: str) -> dict:
    """Send one image to Google Cloud Vision API (OCR + object detection)."""
    url = f"https://vision.googleapis.com/v1/images:annotate?key={GOOGLE_API_KEY}"
    payload = {
        "requests": [{
            "image": {"content": encode_image_to_base64(image_path)},
            "features": [
                {"type": "DOCUMENT_TEXT_DETECTION"},
                {"type": "OBJECT_LOCALIZATION"},
            ]
        }]
    }
    try:
        response = requests.post(url, json=payload, timeout=120)
    except requests.exceptions.Timeout:
        print("   Warning: API request timed out")
        return {}

    if response.status_code != 200:
        print(f"   Warning: Vision API returned status {response.status_code}")
        print(f"   Detail: {response.text[:300]}")
        return {}

    responses = response.json().get("responses", [{}])
    return responses[0] if responses else {}


def extract_full_text(vision_response: dict) -> str:
    """Pull all OCR text out of the Vision API response."""
    full_text = vision_response.get("fullTextAnnotation", {}).get("text", "")
    if full_text:
        return full_text
    annotations = vision_response.get("textAnnotations", [])
    if annotations:
        return annotations[0].get("description", "")
    return ""


